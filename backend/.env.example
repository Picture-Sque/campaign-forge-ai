# Backend Environment Configuration

# Groq API Key (required)
GROQ_API_KEY=gsk_your_actual_key_here

# Frontend URL for CORS (for local development, use localhost:3000)
FRONTEND_URL=http://localhost:3000

# Production Frontend URL (Vercel deployment)
# FRONTEND_URL=https://campaign-forge-frontend.vercel.app

# Backend environment
ENVIRONMENT=development
# ENVIRONMENT=production (for Render deployment)

# Logging
LOG_LEVEL=INFO
